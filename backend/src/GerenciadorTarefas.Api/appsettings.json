{
  "ConnectionStrings": {
    "BancoDados": "Host=localhost;Port=5432;Database=gerenciador_tarefas;Username=postgres;Password=postgres"
  },
  "BancoDados": {
    "AplicarSeedDadosDemonstracao": false
  },
  "AutenticacaoJwt": {
    "ChaveSecreta": "defina-uma-chave-jwt-segura-por-variavel-de-ambiente",
    "Emissor": "GerenciadorTarefas.Api",
    "Publico": "GerenciadorTarefas.Web",
    "ExpiracaoMinutos": 120
  },
  "LimitacaoTaxa": {
    "Global": {
      "PermissoesPorJanela": 120,
      "JanelaEmSegundos": 60,
      "LimiteFila": 0
    },
    "Login": {
      "PermissoesPorJanela": 5,
      "JanelaEmSegundos": 60,
      "LimiteFila": 0
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "Aplicacao": "GerenciadorTarefas.Api",
      "Ambiente": "Producao"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
